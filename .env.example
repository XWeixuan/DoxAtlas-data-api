DATABASE_URL=postgresql://postgres:postgres@postgres:5432/doxatlas_collector

DATA_API_HOST=0.0.0.0
DATA_API_PORT=8028
DATA_API_ALLOWED_CLIENT_IPS=43.135.22.202
DATA_API_TRUST_PROXY_HEADERS=false
DATA_API_DISABLE_IP_ALLOWLIST=false
DATA_API_INIT_DB_ON_STARTUP=true
API_TOKEN=<CHANGE_ME>

# Direct mode keeps local development and smoke runs usable without a proxy API.
# Set api_pool in mainland production to use the original SmartBatch crawler shape:
# 8 pools x 8 threads per pool, 4 proxy slots per pool, 15 proxy IPs per pool.
# GUBA_PROXY_MAX_PER_TASK is for the single ProxyManager path; SmartBatch keeps the original 15-IP-per-pool detail budget.

GUBA_PROXY_MODE=api_pool
GUBA_PROXY_API_URL=https://share.proxy.qg.net/get?key=<QINGGUO_AUTHKEY>&num=1&distinct=true
GUBA_PROXY_TTL_SECONDS=180
GUBA_PROXY_MAX_PER_TASK=3
GUBA_PROXY_API_MIN_INTERVAL_SECONDS=1.05
GUBA_LIST_API_MAX_ATTEMPTS=4
GUBA_LIST_PAGE_SIZE=100
GUBA_MAX_LIST_PAGES=600
GUBA_PROXY_AUTH_USER=<QINGGUO_AUTHKEY>
GUBA_PROXY_AUTH_PASSWORD=<QINGGUO_AUTHPWD>
GUBA_DETAIL_DIRECT_LIMIT=500
