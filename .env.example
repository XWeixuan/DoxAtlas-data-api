DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/doxatlas_collector
POSTGRES_DB=doxatlas_collector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=55432

DATA_API_HOST=0.0.0.0
DATA_API_PORT=8028
DATA_API_ALLOWED_CLIENT_IPS=43.135.22.202
DATA_API_TRUST_PROXY_HEADERS=false
DATA_API_INIT_DB_ON_STARTUP=true

# direct works on servers that can reach EastMoney/Sina/CLS/STCN/Yicai directly.
# Use api_pool when the server needs a rotating proxy endpoint.
GUBA_PROXY_MODE=direct
GUBA_PROXY_API_URL=
GUBA_PROXY_TTL_SECONDS=180
GUBA_PROXY_MAX_PER_TASK=3
GUBA_DETAIL_DIRECT_LIMIT=500
